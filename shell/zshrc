# Path to your oh-my-zsh configuration.
export ZSH=$HOME/.oh-my-zsh

HISTFILE="$HOME/.zsh_history"
HISTSIZE=500000
SAVEHIST=500000
setopt BANG_HIST
setopt EXTENDED_HISTORY
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_SAVE_NO_DUPS
setopt HIST_REDUCE_BLANKS
setopt HIST_VERIFY
setopt HIST_BEEP

export TERM=xterm-256color

# Directories to be prepended to $PATH
declare -a dirs_to_prepend=(
  "/usr/bin"
  "/usr/local/sbin"
  "/usr/local/git/bin"
  "/usr/local/"
  "$HOME/bin"
  "$(brew --prefix coreutils)/libexec/gnubin"
)

# Explicitly configured $PATH
PATH="$PATH:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

for dir in ${(k)dirs_to_prepend[@]}
do
  if [ -d ${dir} ]; then
    PATH="${dir}:$PATH"
  fi
done

unset dirs_to_prepend

export PATH

# oh-my-zsh theme
ZSH_THEME="avit"

# oh-my-zsh plugins
plugins=(history)

# Load the shell dotfiles
for file in $HOME/.{shell_exports,shell_config}; do
  [ -r "$file" ] && [ -f "$file" ] && source "$file";
done;
unset file;

source $ZSH/oh-my-zsh.sh

# Source local extra (private) settings specific to machine if it exists
[ -f ~/.zsh.local ] && source ~/.zsh.local

export PATH="/usr/local/bin:$PATH"

# fnm (fast node manager) — replaces nvm
eval "$(fnm env --use-on-cd --version-file-strategy=recursive --corepack-enabled)"

# zoxide (smart directory jumper) — replaces z
eval "$(zoxide init zsh)"

# fzf (fuzzy finder)
source <(fzf --zsh)

alias k=kubectl
export PATH="/usr/local/opt/curl/bin:$PATH"

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# GST Skills - GitHub Authentication
export GITHUB_TOKEN=$(gh auth token 2>/dev/null)

# Source secrets (API keys etc.)
[ -f ~/.secrets ] && source ~/.secrets

# Added by dennie installer
export PATH="$HOME/.local/bin:$PATH"

# locstat PATH
export PATH="$HOME/.locstat:$PATH"
